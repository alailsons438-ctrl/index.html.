body {
    background-color: #1a1a1a; /* Fundo preto moderno */
    color: #ffffff; /* Texto branco */
    font-family: Arial, sans-serif;
    text-align: center;
    padding: 50px;
}

h1, h2, h3 {
    color: #00ff00; /* Verde neon para a EcoBox */
}

ul {
    list-style: none; /* Tira as bolinhas da lista */
    padding: 0;
    line-height: 2; /* Espaçamento bom entre as linhas */
}

.botao-zap {
    display: inline-block;
    background-color: #25d366; /* Verde do WhatsApp */
    color: white;
    padding: 15px 30px;
    border-radius: 50px; /* Botão arredondado */
    text-decoration: none;
    font-weight: bold;
    font-size: 1.2em;
    margin-top: 30px;
}
